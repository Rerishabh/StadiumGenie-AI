# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/dbname?retryWrites=true&w=majority

# Server port
PORT=5000

# Gemini API Key & Model Configuration
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use. The currently installed @google/generative-ai v0.24.1 (legacy SDK) supports:
#   gemini-1.5-flash      (fast, efficient — recommended for this SDK version)
#   gemini-1.5-pro        (higher quality, slower)
# If you upgrade to @google/genai (new SDK), you can also use:
#   gemini-2.5-flash-preview-05-20   or   gemini-2.0-flash-exp
GEMINI_MODEL=gemini-1.5-flash